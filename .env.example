# ==============================================================
# Howl PA — environment template
# Copy to `~/.config/howl-pa/.env` (or $CLAUDECLAW_CONFIG/.env) and fill.
# `howl-pa setup` collects every required value interactively.
# See docs/setup-guide.md for where to get each credential.
# ==============================================================

# ----- Required -----

# Telegram bot token from @BotFather. DM @BotFather on Telegram,
# run /newbot, follow the prompts.
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (the only ID allowed to DM the bot).
# DM @userinfobot on Telegram to find yours.
ALLOWED_CHAT_ID=

# Claude Code OAuth token (for Claude-backed subagents).
# Inside any Claude Code session run: claude setup-token
# Paste the resulting token here.
CLAUDE_CODE_OAUTH_TOKEN=

# ----- Security (generated by `howl-pa setup`) -----

PIN_HASH=
PIN_SALT=
IDLE_LOCK_MINUTES=30
KILL_PHRASE=

# ----- Dashboard (generated by `howl-pa setup`) -----

DASHBOARD_TOKEN=
DASHBOARD_PORT=3141

# ----- Paths -----

# Runtime config dir. Resolution order:
#   1. HOWL_CONFIG / CLAUDECLAW_CONFIG (explicit override)
#   2. $XDG_CONFIG_HOME/howl-pa
#   3. ~/.claudeclaw (legacy)
#   4. ~/.config/howl-pa
CLAUDECLAW_CONFIG=

# Obsidian vault path. Create the folder structure described in
# docs/vault-conventions.md before starting the bot.
VAULT_PATH=~/Documents/vault

# Optional local thesis/paper drive that `/mirror-thesis` walks.
# Leave blank if you don't use the thesis-mirror feature.
THESIS_PATH=

# ----- Agent behaviour -----

AGENT_TIMEOUT_MS=900000
AGENT_MAX_TURNS=30
SHOW_COST_FOOTER=compact

# ----- Subagent council (local Ollama) -----

# Install Ollama from https://ollama.com. All local, no paid APIs.
# Recommended minimum pulls:
#   ollama pull nomic-embed-text           (for vector memory)
#   ollama pull qwen2.5-coder:3b           (for coder council member)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODELS=qwen2.5-coder:3b
OLLAMA_COUNCIL_MODELS=qwen2.5-coder:3b
OLLAMA_COUNCIL_JUDGE=
COUNCIL_JUDGE=claude

# ----- Google (Gmail + Calendar + Tasks) -----

# Create an OAuth client (type: Desktop app) at
# https://console.cloud.google.com/apis/credentials, then run
# `howl-pa setup:google` to walk through consent. Scopes used:
#   gmail.readonly, gmail.modify, calendar.readonly,
#   calendar.events, tasks
# These two are filled by setup:google; leave blank here.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT=http://127.0.0.1:4141/cb

# Optional: a Gmail label name to filter priority messages when you
# want the importance classifier skipped. Leave blank to ingest all
# inbox messages and LLM-score them for importance.
GMAIL_PRIORITY_LABEL=

# ----- Optional: specialist agent Telegram bots -----

# Each specialist gets its own bot by exporting a matching token.
# Agent ID is the uppercase suffix after TELEGRAM_BOT_TOKEN_.
# See agents/_template/ for the persona file shape.
# TELEGRAM_BOT_TOKEN_THESIS=
# TELEGRAM_BOT_TOKEN_VENTURE=

# ----- Observability -----

LOG_LEVEL=info
NODE_ENV=production
