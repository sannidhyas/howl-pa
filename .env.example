# Core — required
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=
CLAUDE_CODE_OAUTH_TOKEN=

# Agent behaviour
AGENT_TIMEOUT_MS=900000
AGENT_MAX_TURNS=30
SHOW_COST_FOOTER=compact

# Security — set via `npm run setup`
PIN_HASH=
PIN_SALT=
IDLE_LOCK_MINUTES=30
KILL_PHRASE=

# Config + paths
CLAUDECLAW_CONFIG=~/.claudeclaw
VAULT_PATH=~/Documents/projecthowl

# External (filled in later phases — leave empty for Phase 0)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# OLLAMA_URL=http://localhost:11434

# Observability
LOG_LEVEL=info
NODE_ENV=development
