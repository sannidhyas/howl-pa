# Core — required
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=
CLAUDE_CODE_OAUTH_TOKEN=

# Agent behaviour
AGENT_TIMEOUT_MS=900000
AGENT_MAX_TURNS=30
SHOW_COST_FOOTER=compact

# Security — set via `npm run setup`
PIN_HASH=
PIN_SALT=
IDLE_LOCK_MINUTES=30
KILL_PHRASE=

# Config + paths
CLAUDECLAW_CONFIG=~/.claudeclaw
VAULT_PATH=~/Documents/projecthowl
THESIS_PATH=~/Documents/Thesis

# Dashboard (required — generated by `npm run setup`)
DASHBOARD_TOKEN=
DASHBOARD_PORT=3141

# Subagent council
COUNCIL_JUDGE=claude
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODELS=qwen3-coder,ministral-3

# Google (filled by scripts/setup-google.ts)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT=urn:ietf:wg:oauth:2.0:oob
GMAIL_PRIORITY_LABEL=howl-priority

# Observability
LOG_LEVEL=info
NODE_ENV=development
