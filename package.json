{
  "name": "howl-pa",
  "version": "0.0.1",
  "description": "Howl PA — personal Mission Control. Telegram-first assistant that maintains an Obsidian vault, ingests Gmail/Calendar/Google Tasks, and spawns Codex or Claude subagents.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p .",
    "dev": "tsx watch src/index.ts",
    "setup": "tsx scripts/setup.ts",
    "howl": "tsx scripts/howl.ts",
    "council": "tsx scripts/ollama-council.ts",
    "setup:google": "tsx scripts/setup-google.ts",
    "health": "tsx scripts/health.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@hapi/boom": "^10.0.1",
    "@hono/node-server": "^1.13.7",
    "cron-parser": "^4.9.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.30.0",
    "hono": "^4.6.9",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.12.0",
    "pino": "^9.5.0",
    "simple-git": "^3.27.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
